{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.command // \"\"' | grep -qE '^git commit' && bundle exec rubocop lib/ test/ || true",
            "timeout": 60,
            "statusMessage": "Running rubocop lint check..."
          }
        ]
      }
    ]
  }
}
